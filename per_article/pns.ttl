<article/pns> rdf:type ns4kge:Article .
<article/pns> ns4kge:title "Enhancing Knowledge Graph Embedding with Probabilistic Negative Sampling"^^xsd:string .
<article/pns> ns4kge:date "2017"^^xsd:gYear .
<article/pns> ns4kge:proposesNSMethod <ns-method/probabilistic-negative-sampling> .
<article/pns> ns4kge:mentionsNSMethod <ns-method/bernoulli-negative-sampling> .
<article/pns> ns4kge:mentionsKGEModel <kge-model/transe> .
