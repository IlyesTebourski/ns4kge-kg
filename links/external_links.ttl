@prefix void:    <http://rdfs.org/ns/void#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix bibo:    <http://purl.org/ontology/bibo/> .
@base <https://w3id.org/ns4kge/id/> .

################################################################
#  EXTERNAL SOURCE-KG ALIGNMENTS (VoID)
#
#  Each NS4KGE benchmark dataset is a sampled subset of a real-world
#  knowledge graph. We declare the source KG as a void:Dataset and relate
#  it to our benchmark instances with void:subset (subject = superset).
#  Scope: the most-used benchmarks only (by configuration count).
################################################################

<http://rdf.freebase.com/> rdf:type void:Dataset ;
    rdfs:label "Freebase" ;
    void:subset <dataset/fb15k> , <dataset/fb15k-237> .

<http://wordnet-rdf.princeton.edu/> rdf:type void:Dataset ;
    rdfs:label "WordNet" ;
    void:subset <dataset/wn18> , <dataset/wn18rr> .

<https://yago-knowledge.org/> rdf:type void:Dataset ;
    rdfs:label "YAGO" ;
    void:subset <dataset/yago3-10> , <dataset/mkg-y> .

<http://dbpedia.org/> rdf:type void:Dataset ;
    rdfs:label "DBpedia" ;
    void:subset <dataset/db15k> , <dataset/dbpedia-242> .

<http://www.wikidata.org/> rdf:type void:Dataset ;
    rdfs:label "Wikidata" ;
    void:subset <dataset/mkg-w> .

<http://rtw.ml.cmu.edu/rtw/> rdf:type void:Dataset ;
    rdfs:label "NELL" ;
    void:subset <dataset/nell-995> .

<https://www.nlm.nih.gov/research/umls/> rdf:type void:Dataset ;
    rdfs:label "UMLS" ;
    void:subset <dataset/umls> .

