<article/m2ixkg> rdf:type ns4kge:Article .
<article/m2ixkg> ns4kge:title "MixKG: Mixing for harder negative samples in knowledge graph"^^xsd:string .
<article/m2ixkg> ns4kge:date "2022"^^xsd:gYear .
<article/m2ixkg> ns4kge:proposesNSMethod <ns-method/mixkg> .
<article/m2ixkg> ns4kge:mentionsNSMethod <ns-method/uniform-negative-sampling> .
<article/m2ixkg> ns4kge:mentionsNSMethod <ns-method/mixkg-hnm-sf> .
<article/m2ixkg> ns4kge:mentionsNSMethod <ns-method/sans> .
<article/m2ixkg> ns4kge:mentionsNSMethod <ns-method/rw-sans> .
<article/m2ixkg> ns4kge:mentionsNSMethod <ns-method/kbgan> .
<article/m2ixkg> ns4kge:mentionsNSMethod <ns-method/igan> .
<article/m2ixkg> ns4kge:mentionsNSMethod <ns-method/mixkg-hnm-ces> .
<article/m2ixkg> ns4kge:mentionsNSMethod <ns-method/bernoulli-negative-sampling> .
<article/m2ixkg> ns4kge:mentionsNSMethod <ns-method/nscaching> .
<article/m2ixkg> ns4kge:mentionsKGEModel <kge-model/distmult> .
<article/m2ixkg> ns4kge:mentionsKGEModel <kge-model/complex> .
<article/m2ixkg> ns4kge:mentionsKGEModel <kge-model/rotate> .
<article/m2ixkg> ns4kge:mentionsKGEModel <kge-model/transe> .
<article/m2ixkg> ns4kge:hasExperimentation <experimentation/m2ixkg> .

<category/mix-up-ns> rdf:type ns4kge:Category .

<subcategory/standard> rdf:type ns4kge:Subcategory .

<ns-method/mixkg> rdf:type ns4kge:NSMethod .
<ns-method/mixkg> ns4kge:hasCategory <category/mix-up-ns> .
<ns-method/mixkg> ns4kge:hasSubcategory <subcategory/standard> .

<ns-method/uniform-negative-sampling> rdf:type ns4kge:NSMethod .
