<article/selfadv> rdf:type ns4kge:Article .
<article/selfadv> ns4kge:title "RotatE: Knowledge Graph Embedding by Relational Rotation in Complex Space"^^xsd:string .
<article/selfadv> ns4kge:date "2019"^^xsd:gYear .
<article/selfadv> ns4kge:proposesNSMethod <ns-method/self-adversarial-negative-sampling> .
<article/selfadv> ns4kge:mentionsNSMethod <ns-method/kbgan> .
<article/selfadv> ns4kge:mentionsNSMethod <ns-method/uniform-negative-sampling> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/distmult> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/protate> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/stranse> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/conve> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/transh> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/hole> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/transr> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/toruse> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/transe> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/kg2e> .
<article/selfadv> ns4kge:mentionsKGEModel <kge-model/complex> .
<article/selfadv> ns4kge:hasExperimentation <experimentation/selfadv> .

<category/self-adversarial-ns> rdf:type ns4kge:Category .

